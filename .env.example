# SOL/USDT Analyzer — Environment Variables
# Kopiraj ovaj fajl kao .env i popuni vrijednosti

# ── Firebase Cloud Messaging (za Android/iOS push notifikacije) ──────────────
# Preuzmi sa: Firebase Console > Project Settings > Cloud Messaging > Server key
VITE_FCM_SERVER_KEY=your_fcm_server_key_here

# ── Firebase Config (za web app) ─────────────────────────────────────────────
# Preuzmi sa: Firebase Console > Project Settings > General > Web app
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
